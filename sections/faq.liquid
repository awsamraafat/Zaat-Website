    <!-- Getting Started 1 -->
    <div class="glass-card faq-accordion-item" data-category="getting-started" style="padding: 24px; border-radius: var(--border-radius-md); margin-bottom: 16px;">
      <div class="faq-accordion-header accordion-header" style="display: flex; justify-content: space-between; align-items: center; cursor: pointer;">
        <h3 class="faq-question-text" style="font-size: 16px; font-weight: 600;">What is Zaat?</h3>
        <span class="accordion-icon">+</span>
      </div>
      <div class="faq-accordion-content accordion-content">
        <div class="faq-answer-text" style="margin-top: 16px; line-height: 1.6; color: var(--text-gray);">
          Zaat is a smart networking platform that allows you to share your contact information, social media profiles, business details, payment links, and digital content through a single personalized profile.<br><br>
          Your profile can be shared using:<br>
          • NFC Products<br>
          • QR Codes<br>
          • Direct Profile Links<br><br>
          Instead of carrying paper business cards, Zaat allows you to update your information anytime without reprinting anything.
        </div>
      </div>
    </div>
    
    <!-- Getting Started 2 -->
    <div class="glass-card faq-accordion-item" data-category="getting-started" style="padding: 24px; border-radius: var(--border-radius-md); margin-bottom: 16px;">
      <div class="faq-accordion-header accordion-header" style="display: flex; justify-content: space-between; align-items: center; cursor: pointer;">
        <h3 class="faq-question-text" style="font-size: 16px; font-weight: 600;">How Do I Create My Profile?</h3>
        <span class="accordion-icon">+</span>
      </div>
      <div class="faq-accordion-content accordion-content">
        <div class="faq-answer-text" style="margin-top: 16px; line-height: 1.6; color: var(--text-gray);">
          1. Download the Zaat App.<br>
          2. Create a new account.<br>
          3. Verify your email address.<br>
          4. Choose your unique username.<br>
          5. Add your profile information.<br>
          6. Upload your profile image.<br>
          7. Add your social and professional links.<br><br>
          Your profile becomes available immediately after setup.
        </div>
      </div>
    </div>
    
