    <!-- NFC 1 -->
    <div class="glass-card faq-accordion-item" data-category="nfc" style="padding: 24px; border-radius: var(--border-radius-md); margin-bottom: 16px; display: none;">
      <div class="faq-accordion-header accordion-header" style="display: flex; justify-content: space-between; align-items: center; cursor: pointer;">
        <h3 class="faq-question-text" style="font-size: 16px; font-weight: 600;">What Is An NFC Product?</h3>
        <span class="accordion-icon">+</span>
      </div>
      <div class="faq-accordion-content accordion-content">
        <div class="faq-answer-text" style="margin-top: 16px; line-height: 1.6; color: var(--text-gray);">
          NFC stands for Near Field Communication.<br><br>
          Every Zaat product contains a smart NFC chip that allows people to access your profile simply by tapping their phone against the product.<br><br>
          Available products include:<br>
          • NFC Cards<br>
          • Keychains<br>
          • Stickers<br>
          • Desk Stands<br><br>
          No application is required for visitors.
        </div>
      </div>
    </div>
    
    <!-- NFC 2 -->
    <div class="glass-card faq-accordion-item" data-category="nfc" style="padding: 24px; border-radius: var(--border-radius-md); margin-bottom: 16px; display: none;">
