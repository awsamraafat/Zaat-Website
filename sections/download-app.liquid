<div class="download-app-section" style="background: #eef2ff; min-height: 80vh; padding: 120px 24px 80px; display: flex; align-items: center; justify-content: center;">
  <div class="download-page-card" style="background: #ffffff; border-radius: 24px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06); border: 1px solid rgba(226, 232, 240, 0.8); max-width: 900px; width: 100%; padding: 48px 60px; color: #1e293b; display: flex; flex-direction: column; gap: 40px;">
    
    <div style="display: flex; gap: 48px; align-items: center; flex-wrap: wrap;">
      <!-- Left: App Icon Container -->
      <div style="flex: 1 1 200px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #c7d2fe; border-radius: 20px; padding: 40px 20px; box-shadow: inset 0 2px 4px rgba(255,255,255,0.4);">
        <div style="background: #ffffff; width: 110px; height: 110px; border-radius: 24px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(99, 102, 241, 0.25);">
          <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
          </svg>
        </div>
        <div style="font-family: var(--font-title); font-size: 20px; font-weight: 800; color: #1e3a8a; margin-top: 16px;">{{ section.settings.app_name }}</div>
      </div>
      
      <!-- Right: Text Content -->
      <div style="flex: 2 1 400px; display: flex; flex-direction: column; gap: 16px;">
        <h1 style="font-family: var(--font-title); font-size: 38px; font-weight: 800; color: #1e1b4b; line-height: 1.2;">{{ section.settings.title }}</h1>
        <p style="color: #4b5563; font-size: 16px; line-height: 1.6; font-family: var(--font-body);">{{ section.settings.description }}</p>
      </div>
    </div>
    
    <!-- Badges Row -->
    <div style="border-top: 1px solid #e2e8f0; padding-top: 32px; display: flex; justify-content: center; gap: 20px; flex-wrap: wrap;">
      <a href="{{ section.settings.app_store_url | default: '#' }}" style="transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        <svg width="150" height="50" viewBox="0 0 135 40" xmlns="http://www.w3.org/2000/svg">
          <rect width="135" height="40" rx="6" fill="black" stroke="rgba(255,255,255,0.2)" stroke-width="0.8"/>
          <path d="M20.5 15.8c0-2.4 2-3.6 2.1-3.7-1.1-1.6-2.8-1.9-3.4-1.9-1.5-.1-2.9 1-3.7 1-.7 0-1.9-.9-3.1-.9-1.6 0-3.1.9-3.9 2.4-1.7 2.9-.4 7.2 1.2 9.5.8 1.1 1.7 2.4 2.9 2.4 1.2 0 1.6-.7 3.1-.7s1.8.7 3.1.7c1.3 0 2.1-1.2 2.9-2.3.9-1.3 1.3-2.6 1.3-2.6s-2.5-.9-2.5-3.8z" fill="white"/>
          <path d="M18.0 9.2c.7-.8 1.1-1.9 1-3-.9.1-2 .6-2.7 1.4-.6.7-1.1 1.8-1 2.9.9.1 1.9-.5 2.7-1.3z" fill="white"/>
          <text x="35" y="15" fill="white" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="6" font-weight="600" letter-spacing="0.2">Download on the</text>
          <text x="35" y="27" fill="white" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="11" font-weight="700">App Store</text>
        </svg>
      </a>
      <a href="{{ section.settings.google_play_url | default: '#' }}" style="transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        <svg width="150" height="50" viewBox="0 0 135 40" xmlns="http://www.w3.org/2000/svg">
          <rect width="135" height="40" rx="6" fill="black" stroke="rgba(255,255,255,0.2)" stroke-width="0.8"/>
          <g transform="translate(10, 8) scale(0.9)">
            <path d="M1.5 1.1C1.2.9 1 .9.7 1.1L12.5 12.9l2.7-2.7L1.5 1.1z" fill="#EA4335"/>
            <path d="M12.5 12.9L.7 24.7c.3.2.5.2.8 0l13.7-9.1-2.7-2.7z" fill="#34A853"/>
            <path d="M21.5 11L15.2 7.2l-2.7 5.7 2.7 2.7 6.3-4.2c.5-.3.5-1.1 0-1.4z" fill="#FBBC05"/>
            <path d="M1.5 1.1v23.6c0 .6.4.8.8.6l12.9-12.4L1.5 1.1z" fill="#4285F4"/>
          </g>
          <text x="35" y="15" fill="white" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="5.5" font-weight="600" letter-spacing="0.5">GET IT ON</text>
          <text x="35" y="27" fill="white" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="11" font-weight="700">Google Play</text>
        </svg>
      </a>
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Download App Section",
  "settings": [
    {
      "type": "text",
      "id": "app_name",
      "label": "App Name",
      "default": "Zaat App"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Get the App and And Join Us on Mobile!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Page Description",
      "default": "Download the Zaat app to create your digital profile, manage your information, and share your contact details and links instantly with your smart NFC card. Stay connected, look professional, and make every interaction effortless"
    },
    {
      "type": "url",
      "id": "app_store_url",
      "label": "Apple App Store URL"
    },
    {
      "type": "url",
      "id": "google_play_url",
      "label": "Google Play Store URL"
    }
  ]
}
{% endschema %}
