<div class="download-app-section" style="background: #eef2ff; min-height: 80vh; padding: 120px 24px 80px; display: flex; align-items: center; justify-content: center;">
  <div class="download-page-card" style="background: #ffffff; border-radius: 24px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06); border: 1px solid rgba(226, 232, 240, 0.8); max-width: 900px; width: 100%; padding: 48px 60px; color: #1e293b; display: flex; flex-direction: column; gap: 40px;">
    
    <div style="display: flex; gap: 48px; align-items: center; flex-wrap: wrap;">
      <!-- Left: App Icon Container -->
      <div style="flex: 1 1 200px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #c7d2fe; border-radius: 20px; padding: 40px 20px; box-shadow: inset 0 2px 4px rgba(255,255,255,0.4);">
        <div style="background: #ffffff; width: 110px; height: 110px; border-radius: 24px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(99, 102, 241, 0.25); overflow: hidden;">
          {% if section.settings.app_icon != blank %}
            <img src="{{ section.settings.app_icon | img_url: '300x' }}" alt="Zaat App Icon" style="width: 100%; height: 100%; object-fit: cover;">
          {% else %}
            <img src="{{ 'Icon-App-29x29@3x.png' | asset_url }}" alt="Zaat App Icon" style="width: 100%; height: 100%; object-fit: cover;">
          {% endif %}
        </div>
        <div style="font-family: var(--font-title); font-size: 20px; font-weight: 800; color: #1e3a8a; margin-top: 16px;">Zaat App</div>
      </div>
      
      <!-- Right: Text Content -->
      <div style="flex: 2 1 400px; display: flex; flex-direction: column; gap: 16px;">
        <h1 style="font-family: var(--font-title); font-size: 38px; font-weight: 800; color: #1e1b4b; line-height: 1.2;">{{ section.settings.title }}</h1>
        <p style="color: #4b5563; font-size: 16px; line-height: 1.6; font-family: var(--font-body);">{{ section.settings.description }}</p>
      </div>
    </div>
    
    <!-- Badges Row -->
    <div style="border-top: 1px solid #e2e8f0; padding-top: 32px; display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;">
      <!-- App Store Badge -->
      <a href="{{ section.settings.app_store_url | default: '#' }}">
        <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" alt="Download on the App Store" style="height: 48px; border-radius: 8px;">
      </a>

      <!-- Google Play Badge -->
      <a href="{{ section.settings.google_play_url | default: '#' }}">
        <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" alt="Get it on Google Play" style="height: 48px; border-radius: 8px;">
      </a>
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Download App Section",
  "settings": [
    {
      "type": "text",
      "id": "app_name",
      "label": "App Name",
      "default": "Zaat App"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Get the App and And Join Us on Mobile!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Page Description",
      "default": "Download the Zaat app to create your digital profile, manage your information, and share your contact details and links instantly with your smart NFC card. Stay connected, look professional, and make every interaction effortless"
    },
    {
      "type": "url",
      "id": "app_store_url",
      "label": "Apple App Store URL"
    },
    {
      "type": "url",
      "id": "google_play_url",
      "label": "Google Play Store URL"
    }
  ]
}
{% endschema %}
