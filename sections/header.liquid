<header class="site-header">
  <div class="container header-container">
    <div class="logo">
      <a href="/" style="display: block;">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | img_url: '300x' }}" alt="{{ shop.name }}" style="height: 80px; width: auto; display: block;">
        {% else %}
          <img src="{{ 'logo.gif' | asset_url }}" alt="Zaat Logo" style="height: 80px; width: auto; display: block;">
        {% endif %}
      </a>
    </div>

    <button class="mobile-nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav>
      <ul class="nav-menu">
        {% for link in linklists[section.settings.menu].links %}
          <li>
            <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">{{ link.title }}</a>
          </li>
        {% else %}
          <li><a href="/pages/faq" class="nav-link">Help Center</a></li>
          <li><a href="/collections/all" class="nav-link">Collection</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/account" class="action-icon" aria-label="Account">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="11" fill="#cbdcfb"/>
          <path d="M12 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V18h14v-1.5c0-2.33-4.67-3.5-7-3.5z" fill="#2563eb"/>
        </svg>
      </a>
      <a href="/cart" class="action-icon" aria-label="Cart" id="cart-icon-btn">
        <div style="position: relative; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="#2563eb" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 6h-2c0-2.76-2.24-5-5-5S7 3.24 7 6H5c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-7-3c1.66 0 3 1.34 3 3H9c0-1.66 1.34-3 3-3zm0 10c-2.76 0-5-2.24-5-5h2c0 1.66 1.34 3 3 3s3-1.34 3-3h2c0 2.76-2.24 5-5 5z"/>
          </svg>
          <span class="cart-count" style="position: absolute; top: 9px; left: 0; right: 0; text-align: center; color: #ffffff; font-size: 8px; font-weight: 700; font-family: sans-serif; line-height: 1;">{{ cart.item_count }}</span>
        </div>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
