<section class="hero-section-wix">
  <!-- Centered Text -->
  <div class="hero-text-center">
    <h1 class="hero-title-wix">{{ section.settings.title }}</h1>
    <p class="hero-desc-wix">{{ section.settings.description }}</p>
  </div>

  <!-- Blob + Card + Floating Cards Container -->
  <div class="hero-blob-wrapper">
    <!-- Center Assets container for perfect alignment and sync'd floating -->
    <div class="hero-center-assets">
      <!-- Ambient Blue Glow behind the blob -->
      <img src="{{ 'hero-bg-glow.png' | asset_url }}" alt="Blue ambient glow" class="hero-blob-glow">

      <!-- Blue Blob Image -->
      <img src="{{ 'hero-bg-liquid.png' | asset_url }}" alt="Blue glossy blob" class="hero-blob-img">

      <!-- Black NFC Card floating on blob -->
      <div class="hero-nfc-card">
        {% if section.settings.nfc_card != blank %}
          <img src="{{ section.settings.nfc_card | img_url: '600x' }}" alt="Zaat NFC Card">
        {% else %}
          <img src="{{ 'card-black-edition.png' | asset_url }}" alt="Zaat NFC Card">
        {% endif %}
      </div>
    </div>

    <!-- Left Info Card -->
    <div class="hero-info-card hero-info-left">
      <div class="hero-info-photo">
        <img src="{{ 'hero-woman.png' | asset_url }}" alt="Person smiling">
      </div>
      <div class="hero-info-body">
        <h3>{{ section.settings.left_card_title }}</h3>
        <p>{{ section.settings.left_card_desc }}</p>
        <a href="{{ section.settings.button_url }}" class="hero-info-btn" style="text-decoration: none; display: inline-block; text-align: center;">{{ section.settings.button_text }}</a>
      </div>
    </div>

    <!-- Right Info Card -->
    <div class="hero-info-card hero-info-right">
      <div class="hero-info-icon-container">
        <img src="{{ 'hero-nfc-icon.png' | asset_url }}" alt="NFC icon" class="hero-nfc-icon-img">
      </div>
      <div class="hero-info-body">
        <h3>{{ section.settings.right_card_title }}</h3>
        <p>{{ section.settings.right_card_desc }}</p>
      </div>
    </div>
  </div>

  <!-- Zaatlink Watermark Section -->
  <div class="hero-watermark">
    <span class="hero-watermark-text">{{ section.settings.watermark_text }}</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Upgrade the way you connect with one smart card."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Seamlessly share your profile, social media, and contact information using Zaat's NFC technology - all in one powerful card."
    },
    {
      "type": "image_picker",
      "id": "nfc_card",
      "label": "NFC Card Image"
    },
    {
      "type": "text",
      "id": "left_card_title",
      "label": "Left Card Title",
      "default": "Tap. Share. Connect."
    },
    {
      "type": "textarea",
      "id": "left_card_desc",
      "label": "Left Card Description",
      "default": "Share everything about you instantly with your Zaat smart card."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "right_card_title",
      "label": "Right Card Title",
      "default": "Your digital identity, simplified"
    },
    {
      "type": "textarea",
      "id": "right_card_desc",
      "label": "Right Card Description",
      "default": "Keep all your important links and contact details in one powerful profile."
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Watermark Text",
      "default": "Zaatlink"
    }
  ]
}
{% endschema %}
