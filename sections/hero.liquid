<section class="hero-section">
  <div class="container hero-grid">
    <!-- Hero Info -->
    <div class="hero-content">
      <div class="hero-tagline">{{ section.settings.tagline }}</div>
      <h1 class="hero-title">{{ section.settings.title }}</h1>
      <p class="hero-description">{{ section.settings.description }}</p>
      <div style="display: flex; gap: 16px;">
        <a href="{{ section.settings.button_url }}" class="btn btn-primary">{{ section.settings.button_text }}</a>
        <a href="#explore" class="btn btn-secondary">Learn More</a>
      </div>
    </div>
    
    <!-- Hero Media / Glass Cards -->
    <div class="hero-image-wrapper">
      <img src="{{ 'hero-bg-liquid.png' | asset_url }}" alt="Fluid Glossy render" class="hero-bg-blob">
      
      <!-- Card 1: Left -->
      <div class="glass-card hero-card-floating hero-card-left" style="padding: 16px; border-radius: 16px; display: flex; gap: 12px; align-items: center;">
        <div style="width: 48px; height: 48px; border-radius: 50%; overflow: hidden; background: #e2e8f0;">
          <!-- SVG default user avatar profile for fallback -->
          <svg viewBox="0 0 100 100" style="width:100%; height:100%; fill:#4a5568;"><circle cx="50" cy="40" r="25"/><path d="M10 90 Q50 60 90 90 Z"/></svg>
        </div>
        <div>
          <div style="font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 2px;">Tap. Share. Connect.</div>
          <div style="font-size: 11px; color: var(--text-gray);">Instantly exchange contacts</div>
        </div>
      </div>

      <!-- Card 2: Right -->
      <div class="glass-card hero-card-floating hero-card-right" style="padding: 16px; border-radius: 16px; display: flex; gap: 12px; align-items: center;">
        <div style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: rgba(59,130,246,0.1); border-radius: 50%; color: var(--accent-blue);">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>
        </div>
        <div>
          <div style="font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 2px;">Smart Identity</div>
          <div style="font-size: 11px; color: var(--text-gray);">Simplified for professionals</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "UPGRADE YOUR CONNECTION"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Upgrade the way you connect with one smart card."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Seamlessly share your profile, social media, and contact information using Zaat's NFC technology - all in one powerful card."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
