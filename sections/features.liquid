<section class="features-section section-padding" id="explore">
  <div class="container">
    
    <!-- Section Header -->
    <div class="section-header">
      <h2 class="section-title">A Smarter Way to Share Your Identity</h2>
      <p class="section-desc">Create your digital profile, add your contact details, and update them instantly. Networking has never been this simple, fast, and secure.</p>
    </div>
    
    <!-- Core App Features Grid -->
    <div class="features-grid" style="margin-bottom: 100px;">
      <!-- Left Column -->
      <div class="features-col">
        <div class="feature-item glass-card">
          <div class="feature-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <div>
            <h3 class="feature-item-title">Smart Profile</h3>
            <p class="feature-item-desc">Create your digital profile and add your contact details, social media, and personal links easily through the Zaat app.</p>
          </div>
        </div>
        
        <div class="feature-item glass-card">
          <div class="feature-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          </div>
          <div>
            <h3 class="feature-item-title">All-in-One Links</h3>
            <p class="feature-item-desc">Keep your social platforms, websites, and contact details organized in one smart profile link.</p>
          </div>
        </div>
      </div>
      
      <!-- Center Phone Mockup -->
      <div class="features-center-phone">
        <img src="{{ 'phone-mockup.png' | asset_url }}" alt="Zaat App Mockup" class="phone-img">
      </div>
      
      <!-- Right Column -->
      <div class="features-col">
        <div class="feature-item glass-card">
          <div class="feature-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 6H3a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2z"></path><path d="M23 9l-4 3 4 3V9z"></path></svg>
          </div>
          <div>
            <h3 class="feature-item-title">Tap to Share</h3>
            <p class="feature-item-desc">Tap your Zaat card on a smartphone to instantly share your profile, contact info, and social links using NFC technology.</p>
          </div>
        </div>
        
        <div class="feature-item glass-card">
          <div class="feature-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
          </div>
          <div>
            <h3 class="feature-item-title">Live Updates</h3>
            <p class="feature-item-desc">Update your information anytime from the app and your card will always share the latest version instantly.</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- How to Get Started Section -->
    <div class="radial-get-started" style="margin-bottom: 100px;">
      <!-- Radial Visual Ring -->
      <div class="radial-container">
        <div class="radial-center">
          <img src="{{ 'app-icon.png' | asset_url }}" alt="Zaat App" style="width: 56px; height: 56px; border-radius: 12px;">
        </div>
        <!-- Position radial links relative to center -->
        <div class="radial-item" style="top: 10%; left: 45%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </div>
        <div class="radial-item" style="top: 25%; right: 15%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </div>
        <div class="radial-item" style="bottom: 25%; right: 15%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </div>
        <div class="radial-item" style="bottom: 10%; left: 45%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
        </div>
        <div class="radial-item" style="bottom: 25%; left: 15%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </div>
        <div class="radial-item" style="top: 25%; left: 15%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </div>
      </div>
      
      <!-- Steps Text Info -->
      <div class="how-it-works-content">
        <h2 class="section-title">How to Get Started</h2>
        <div class="step-card">
          <div class="step-number">01</div>
          <h3 style="font-size: 18px; margin-bottom: 8px;">Download the App</h3>
          <p style="color: var(--text-gray); font-size: 14px;">This is the space to introduce the Services section. Briefly describe the types of services offered and highlight any special benefits or features.</p>
        </div>
        <div class="step-card">
          <div class="step-number">02</div>
          <h3 style="font-size: 18px; margin-bottom: 8px;">Customize Your Card</h3>
          <p style="color: var(--text-gray); font-size: 14px;">Select from a range of high-quality premium textures and colors, add your custom embossed name and title to match your brand.</p>
        </div>
      </div>
    </div>
    
    <!-- Showcase Banner with floating cards mockup -->
    <div style="margin-bottom: 100px;">
      <div class="section-header">
        <h2 class="section-title">Premium Card Showcase</h2>
        <p class="section-desc">Pick a Zaat card that fits your personality and start sharing your profile, links, and contact info with one tap.</p>
      </div>
      
      <div class="showcase-banner">
        {% if section.settings.showcase_banner != blank %}
          <img src="{{ section.settings.showcase_banner | img_url: '1600x' }}" alt="Friends holding smart cards" class="showcase-bg-img">
        {% else %}
          <img src="{{ 'express-identity-banner.png' | asset_url }}" alt="Friends holding smart cards" class="showcase-bg-img">
        {% endif %}
        <div class="showcase-overlay"></div>
        <div class="showcase-content">
          <h3 style="font-size: 32px; margin-bottom: 16px;">Express Your Identity in Style</h3>
          <p style="color: var(--text-gray); margin-bottom: 24px;">Our NFC business cards are custom engraved with premium lasers on steel, wood, and carbon fibre, giving you an elite look.</p>
          <a href="/collections/all" class="btn btn-primary">Explore Collections</a>
        </div>
      </div>
    </div>

    <!-- Floating Diagonal Deck -->
    <div class="floating-deck-container">
      {% if section.settings.deck_card_1 != blank %}
        <img class="deck-card" src="{{ section.settings.deck_card_1 | img_url: '600x' }}" alt="NFC Card 1">
      {% else %}
        <img class="deck-card" src="{{ 'card-black-edition.png' | asset_url }}" alt="NFC Black Edition">
      {% endif %}

      {% if section.settings.deck_card_2 != blank %}
        <img class="deck-card" src="{{ section.settings.deck_card_2 | img_url: '600x' }}" alt="NFC Card 2">
      {% else %}
        <img class="deck-card" src="{{ '12.png' | asset_url }}" alt="NFC Custom Design 1">
      {% endif %}

      {% if section.settings.deck_card_3 != blank %}
        <img class="deck-card" src="{{ section.settings.deck_card_3 | img_url: '600x' }}" alt="NFC Card 3">
      {% else %}
        <img class="deck-card" src="{{ 'card-pink-edition.png' | asset_url }}" alt="NFC Pink Edition">
      {% endif %}

      {% if section.settings.deck_card_4 != blank %}
        <img class="deck-card" src="{{ section.settings.deck_card_4 | img_url: '600x' }}" alt="NFC Pink Edition">
      {% else %}
        <img class="deck-card" src="{{ '13.png' | asset_url }}" alt="NFC Pink Edition">
      {% endif %}
      
      <div class="circular-text-deck">
        <h3 style="font-size:20px; margin-bottom:8px;">Choose Your Style.</h3>
        <p style="color:var(--text-gray); font-size:12px; margin-bottom:16px;">Share your digital identity with a simple tap.</p>
        <a href="/collections/all" class="btn btn-primary" style="padding: 8px 20px; font-size: 13px;">Explore Collections</a>
      </div>
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Features Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "showcase_banner",
      "label": "Showcase Banner Background Image"
    },
    {
      "type": "image_picker",
      "id": "deck_card_1",
      "label": "Deck Card 1 (Black)"
    },
    {
      "type": "image_picker",
      "id": "deck_card_2",
      "label": "Deck Card 2 (Violet)"
    },
    {
      "type": "image_picker",
      "id": "deck_card_3",
      "label": "Deck Card 3 (Design 2)"
    },
    {
      "type": "image_picker",
      "id": "deck_card_4",
      "label": "Deck Card 4 (Pink)"
    }
  ]
}
{% endschema %}
