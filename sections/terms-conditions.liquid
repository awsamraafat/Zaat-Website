<style>
  .terms-nav-link {
    font-size: 15px;
    color: var(--text-gray);
    display: block;
    padding: 6px 0;
    transition: color 0.2s;
    text-decoration: none;
  }
  .terms-nav-link:hover {
    color: var(--text-white);
  }
  .terms-nav-link.active-tab {
    color: var(--accent-blue) !important;
    font-weight: 600 !important;
  }
</style>

<div class="faq-banner" style="background: linear-gradient(180deg, #131722 0%, #0d0f14 100%);">
  <div class="container">
    <h1 style="font-size: 48px; margin-bottom: 16px;">Terms & Conditions</h1>
    <p style="color: var(--text-gray); max-width: 600px; margin: 0 auto;">Last Updated: June 2026</p>
  </div>
</div>

<section class="container section-padding">
  <div style="display: grid; grid-template-columns: 280px 1fr; gap: 60px; align-items: start;">
    
    <!-- Left Navigation Sidebar -->
    <aside class="terms-sidebar" style="position: sticky; top: 130px; display: flex; flex-direction: column; gap: 12px;">
      <h4 style="font-size: 14px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Sections</h4>
      <a href="#welcome" class="terms-nav-link active-tab" data-target="welcome">Welcome</a>
      <a href="#acceptance" class="terms-nav-link" data-target="acceptance">1. Acceptance of Terms</a>
      <a href="#accounts" class="terms-nav-link" data-target="accounts">2. User Accounts</a>
      <a href="#profiles" class="terms-nav-link" data-target="profiles">3. Digital Profiles</a>
      <a href="#use" class="terms-nav-link" data-target="use">4. Acceptable Use</a>
      <a href="#nfc" class="terms-nav-link" data-target="nfc">5. NFC Products & QR Codes</a>
      <a href="#intellectual" class="terms-nav-link" data-target="intellectual">6. Intellectual Property</a>
      <a href="#availability" class="terms-nav-link" data-target="availability">7. Service Availability</a>
      <a href="#limitation" class="terms-nav-link" data-target="limitation">8. Limitation of Liability</a>
      <a href="#termination" class="terms-nav-link" data-target="termination">9. Termination</a>
      <a href="#changes" class="terms-nav-link" data-target="changes">10. Changes to Terms</a>
      <a href="#governing" class="terms-nav-link" data-target="governing">11. Governing Law</a>
      <a href="#contact" class="terms-nav-link" data-target="contact">12. Contact</a>
    </aside>

    <!-- Right Content Body -->
    <div class="glass-card" style="padding: 48px; border-radius: var(--border-radius-lg); display: flex; flex-direction: column; line-height: 1.8;">
      
      <div id="welcome" class="terms-content-tab" style="display: block;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">Welcome to Zaat</h2>
        <p style="color: var(--text-gray);">By accessing or using our website, mobile application, NFC products, QR services, or digital profile platform, you agree to these Terms & Conditions.</p>
      </div>

      <div id="acceptance" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">1. Acceptance of Terms</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">By creating an account or using any Zaat service, you agree to comply with these Terms.</p>
        <p style="color: var(--text-gray);">If you do not agree, you should discontinue use of the services.</p>
      </div>

      <div id="accounts" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">2. User Accounts</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">Users are responsible for:</p>
        <ul style="color: var(--text-gray); padding-left: 20px; display: flex; flex-direction: column; gap: 10px;">
          <li>Maintaining account security</li>
          <li>Protecting login credentials</li>
          <li>Ensuring information provided is accurate</li>
          <li>All activities performed under their account</li>
        </ul>
      </div>

      <div id="profiles" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">3. Digital Profiles</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">Users may create public digital profiles containing personal, professional, and social information.</p>
        <p style="color: var(--text-gray);">You are solely responsible for the content you publish.</p>
      </div>

      <div id="use" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">4. Acceptable Use</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">You may not use Zaat to:</p>
        <ul style="color: var(--text-gray); padding-left: 20px; display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px;">
          <li>Violate applicable laws</li>
          <li>Impersonate another individual or organization</li>
          <li>Distribute harmful, fraudulent, or misleading content</li>
          <li>Upload malicious software</li>
          <li>Abuse platform functionality</li>
        </ul>
        <p style="color: var(--text-gray);">Zaat reserves the right to suspend or terminate accounts that violate these rules.</p>
      </div>

      <div id="nfc" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">5. NFC Products & QR Codes</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">Zaat NFC products and QR codes are intended for networking and information-sharing purposes.</p>
        <p style="color: var(--text-gray);">Users are responsible for ensuring profile information remains accurate and appropriate.</p>
      </div>

      <div id="intellectual" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">6. Intellectual Property</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">All Zaat trademarks, branding, software, designs, graphics, and platform content remain the property of Zaat.</p>
        <p style="color: var(--text-gray);">Users may not copy, reproduce, or distribute platform assets without permission.</p>
      </div>

      <div id="availability" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">7. Service Availability</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">We strive to provide uninterrupted access to our services.</p>
        <p style="color: var(--text-gray);">However, we do not guarantee continuous availability and may perform maintenance, updates, or improvements at any time.</p>
      </div>

      <div id="limitation" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">8. Limitation of Liability</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">To the maximum extent permitted by law, Zaat shall not be liable for:</p>
        <ul style="color: var(--text-gray); padding-left: 20px; display: flex; flex-direction: column; gap: 10px;">
          <li>Indirect damages</li>
          <li>Lost profits</li>
          <li>Lost business opportunities</li>
          <li>Data loss</li>
          <li>Service interruptions</li>
        </ul>
      </div>

      <div id="termination" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">9. Termination</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">We may suspend or terminate accounts that:</p>
        <ul style="color: var(--text-gray); padding-left: 20px; display: flex; flex-direction: column; gap: 10px;">
          <li>Violate these Terms</li>
          <li>Abuse the platform</li>
          <li>Create security risks</li>
          <li>Engage in fraudulent activity</li>
        </ul>
      </div>

      <div id="changes" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">10. Changes to Terms</h2>
        <p style="color: var(--text-gray); margin-bottom: 12px;">We may modify these Terms from time to time.</p>
        <p style="color: var(--text-gray);">Continued use of Zaat after updates constitutes acceptance of the revised Terms.</p>
      </div>

      <div id="governing" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">11. Governing Law</h2>
        <p style="color: var(--text-gray);">These Terms shall be governed by the applicable laws of the Arab Republic of Egypt.</p>
      </div>

      <div id="contact" class="terms-content-tab" style="display: none;">
        <h2 style="font-size: 24px; margin-bottom: 16px; color: var(--text-white); font-family: var(--font-title);">12. Contact</h2>
        <p style="color: var(--text-gray); margin-bottom: 16px;">For legal inquiries, please contact:</p>
        <ul style="color: var(--text-gray); padding-left: 20px; display: flex; flex-direction: column; gap: 8px;">
          <li>Email: <a href="mailto:info@zaatlink.com" style="color: var(--accent-blue);">info@zaatlink.com</a></li>
        </ul>
        <p style="color: var(--text-gray); margin-top: 24px; font-weight: 500;">By using Zaat, you acknowledge that you have read and accepted these Terms & Conditions.</p>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navLinks = document.querySelectorAll('.terms-nav-link');
    const contentTabs = document.querySelectorAll('.terms-content-tab');
    
    if (navLinks.length > 0 && contentTabs.length > 0) {
      navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = link.getAttribute('data-target');
          
          // Update active link styling
          navLinks.forEach(l => l.classList.remove('active-tab'));
          link.classList.add('active-tab');
          
          // Switch visible content tab
          contentTabs.forEach(tab => {
            tab.style.display = 'none';
          });
          const activeTab = document.getElementById(targetId);
          if (activeTab) {
            activeTab.style.display = 'block';
          }
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Terms & Conditions",
  "settings": []
}
{% endschema %}
